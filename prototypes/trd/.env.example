# ════════════════════════════════════════════════════════════════════
# Environment variables — example
# ────────────────────────────────────────────────────────────────────
# Copy to .env.local for local development (never commit .env.local).
# Use .env.qa / .env.production for build-time values per environment.
#
# All vars MUST be prefixed with VITE_ to be exposed to the client.
# ════════════════════════════════════════════════════════════════════

# App identity
VITE_APP_NAME="Ardua — Template"
VITE_APP_ENV="local"

# API
VITE_API_BASE_URL="http://localhost:3000/api"
VITE_API_TIMEOUT_MS="15000"

# Mock Service Worker — when "true", MSW intercepts every HTTP call and
# responds with handlers in src/mocks/handlers/. Set to "true" in .env.local
# while iterating on the prototype; leave "false" in .env.qa / .env.production.
VITE_USE_MOCKS="false"

# Auth0
VITE_AUTH0_DOMAIN=""
VITE_AUTH0_CLIENT_ID=""
VITE_AUTH0_AUDIENCE=""

# Feature flags (LaunchDarkly — opt-in plugin)
VITE_LAUNCHDARKLY_CLIENT_SIDE_ID=""

# Feature toggles
VITE_FEATURE_I18N="false"
VITE_FEATURE_LAUNCHDARKLY="false"
