{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ardua.local/manifests/_schema.json",
  "title": "Action Manifest",
  "description": "Schema declarativo de Acciones para los módulos del financial-core de Ardua. Ver framework/marco-dimensiones-registros.md §9 y framework/financial-core-modules.md §11.",
  "type": "object",
  "required": ["app", "module"],
  "additionalProperties": false,
  "properties": {
    "app": {
      "type": "string",
      "description": "App del core (fin, ops, trd, lex, clp, com, framework para genéricos)."
    },
    "module": {
      "type": "string",
      "description": "Módulo dentro de la app."
    },
    "record_type": {
      "type": ["string", "null"],
      "description": "Tipo de registro al que aplica el manifest. null cuando el manifest es a nivel módulo (solo module_ctas, sin acciones contextuales sobre registros)."
    },
    "scope": {
      "type": "string",
      "enum": ["record", "module"],
      "description": "Alcance del manifest. 'record' = acciones sobre un registro de un tipo dado. 'module' = CTAs del header del módulo. Default 'record' si record_type está presente, 'module' si record_type es null."
    },
    "schema_version": {
      "type": "string",
      "description": "Versión del schema (semver). Default '1.0'."
    },
    "required_imputations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Default global de campos requeridos para que el registro alcance estado 'imputado'. Sobrescribible por record_type via required_by_type."
    },
    "required_by_type": {
      "type": "object",
      "description": "Map de tipo de registro a lista de campos requeridos para llegar a 'imputado'.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "kanban_axes": {
      "type": "array",
      "description": "Ejes del Kanban que el manifest gobierna. Cada eje mapea un axis_id (registrado en MOD_REG.axes) a una dimension del manifest y declara la columna destino terminal. El motor compone el dialog uniendo los dialog.fields[] de las acciones cuya dimension matchee y enable_when sea true sobre el registro.",
      "items": {
        "type": "object",
        "required": ["axis_id", "dimension"],
        "additionalProperties": false,
        "properties": {
          "axis_id": { "type": "string" },
          "dimension": { "$ref": "#/definitions/dimension" },
          "drop_target_state": {
            "type": "string",
            "description": "Columna destino terminal del eje (ej. 'imputado'). Cards en este estado no son draggables (consistente con: no Re-imputar v1; salvo edición vía drag inverso)."
          },
          "states": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Estados (columnas) del eje en orden, ej ['pendiente','en_proceso','imputado']."
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "Acciones contextuales sobre un registro. Vacío si scope='module'.",
      "items": { "$ref": "#/definitions/action" }
    },
    "module_ctas": {
      "type": "array",
      "description": "CTAs del header del módulo (Crear, Cargar manual, Exportar, etc). No están atados a un registro existente.",
      "items": { "$ref": "#/definitions/module_cta" }
    }
  },
  "definitions": {
    "dimension": {
      "type": "string",
      "enum": ["imputacion", "registro_contable", "conciliacion", "governance", "documentacion", "cierre"]
    },
    "action": {
      "type": "object",
      "required": ["id", "dimension", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador global. Convención: [app].[modulo].[tipo].[dimension].[verbo_subject]."
        },
        "dimension": { "$ref": "#/definitions/dimension" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string", "description": "Identificador de icono (resuelto por el motor)." },
        "danger": { "type": "boolean", "description": "Visualmente destacada como peligrosa." },
        "target_field": {
          "type": ["string", "null"],
          "description": "Campo del registro que la acción asigna al confirmar. null si la acción no muta un campo específico (ej. exportar)."
        },
        "show_when": { "$ref": "#/definitions/predicate" },
        "enable_when": { "$ref": "#/definitions/predicate" },
        "disable_reason": { "type": "string" },
        "disable_tag": { "type": "string", "description": "Tag visible cuando la acción aparece deshabilitada (ej. 'V2', 'Estado', 'Permiso')." },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "message"],
            "additionalProperties": false,
            "properties": {
              "field": { "type": "string" },
              "value": { "description": "Valor que debe tener el campo. Si se omite, basta con que el campo no sea null." },
              "message": { "type": "string" }
            }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required_role_any_of": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_role_all_of": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "dialog": { "$ref": "#/definitions/dialog" },
        "on_confirm": { "$ref": "#/definitions/on_confirm" },
        "batch": { "$ref": "#/definitions/batch" }
      }
    },
    "module_cta": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "dimension": { "$ref": "#/definitions/dimension" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "is_module_cta": { "type": "boolean" },
        "creates_record_type": {
          "type": "string",
          "description": "Si el CTA crea un nuevo registro, el tipo del registro creado."
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required_role_any_of": { "type": "array", "items": { "type": "string" } },
            "required_role_all_of": { "type": "array", "items": { "type": "string" } }
          }
        },
        "dialog": { "$ref": "#/definitions/dialog" },
        "on_confirm": { "$ref": "#/definitions/on_confirm" }
      }
    },
    "predicate": {
      "type": "object",
      "description": "Predicado evaluable contra un registro. Soporta los operadores documentados en §3.4 del prompt.",
      "additionalProperties": true,
      "properties": {
        "record_type_in":     { "type": "array", "items": { "type": "string" } },
        "record_type_not_in": { "type": "array", "items": { "type": "string" } },
        "field_is_null":      { "type": "string" },
        "field_is_not_null":  { "type": "string" },
        "field_equals": {
          "type": "object",
          "required": ["field", "value"],
          "properties": {
            "field": { "type": "string" },
            "value": {}
          }
        },
        "field_in": {
          "type": "object",
          "required": ["field", "values"],
          "properties": {
            "field":  { "type": "string" },
            "values": { "type": "array" }
          }
        },
        "all": { "type": "array", "items": { "$ref": "#/definitions/predicate" } },
        "any": { "type": "array", "items": { "$ref": "#/definitions/predicate" } }
      }
    },
    "dialog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title":         { "type": "string" },
        "description":   { "type": "string" },
        "fields":        { "type": "array", "items": { "$ref": "#/definitions/field" } },
        "confirm_label": { "type": "string" },
        "cancel_label":  { "type": "string" }
      }
    },
    "field": {
      "type": "object",
      "required": ["id", "label", "type"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "label":       { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["lookup", "text", "textarea", "select", "date", "number", "boolean"]
        },
        "catalog":     { "type": "string", "description": "Identificador de catálogo para type='lookup' (ej. clp.clientes)." },
        "catalog_filter": {
          "type": "object",
          "description": "Filtro a aplicar al catálogo, ej {field: 'sociedad_id', from_record: 'sociedad_id'}.",
          "additionalProperties": true
        },
        "options": {
          "type": "array",
          "description": "Opciones para type='select'.",
          "items": {
            "type": "object",
            "required": ["value", "label"],
            "properties": {
              "value": {},
              "label": { "type": "string" }
            }
          }
        },
        "required":    { "type": "boolean" },
        "placeholder": { "type": "string" },
        "hint":        { "type": "string" },
        "max_length":  { "type": "integer", "minimum": 1 },
        "min":         { "type": "number" },
        "max":         { "type": "number" },
        "default":     {}
      }
    },
    "on_confirm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "update_fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lista de campos del registro que la acción actualiza al confirmar."
        },
        "recompute": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Estados calculados a recomputar (ej. 'imputacion')."
        },
        "audit": { "type": "boolean" },
        "toast": { "type": "string" }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "batchable": { "type": "boolean" },
        "homogeneity_check": {
          "type": "array",
          "items": { "type": "string" }
        },
        "min_records": { "type": "integer", "minimum": 1 },
        "max_records": { "type": "integer", "minimum": 1 },
        "promote_to_main_cta":     { "type": "boolean" },
        "main_cta_label_template": { "type": "string", "description": "Template con placeholder {N} para el conteo." }
      }
    }
  }
}
