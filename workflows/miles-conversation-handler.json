    "method": "POST"
  },
  "description": "Core conversational handler for the Miles REQ creation flow. Receives events from miles-slack-event-router (sources: claude, mention, thread_reply). Routes Claude-sourced messages through a structured parser (Parse Claude Message) that extracts area, problema, contexto, impacto, resultado_esperado, urgencia directly from the formatted Claude output. For human messages, fetches thread history, runs an intent detection heuristic (Detect Intent), then calls Groq Llama 3.3 70B via LangChain to determine intent (req-new, req-list, req-status, unclear) and manage the multi-turn conversation. Confirmed req-new intents go through an approval gate (Fetch Approval Config from Notion DB f698c2da) before creating the ticket in Jira REQ project. After creation, triggers miles-canvas-area-refresh sub-workflow to update the area Slack Canvas.",
  "nodes": [
    "Trigger — Conversation Event",
    "Respond — Acknowledge",
    "Extract Event Data",
    "Is Source Claude?",
    "Parse Claude Message",
    "Fetch Thread History",
    "Is Notification Thread?",
    "Has Miles Been Active?",
    "Is Session Closed?",
    "Is Mention Source?",
    "Post — Thread Has REQ",
    "Build Prompt with History",
    "Detect Intent",
    "LLM Chain — Process Step",
    "Groq — Llama 3.3 70B",
    "Parse AI Response",
    "Switch — Intent Router",
    "Build Jira Payload",
    "Has Minimum Context?",
    "Code — Build Jira Body",
    "Fetch Approval Config",
    "Check Approval Gate",
    "IF — Needs Approval?",
    "Build Approval Buttons Body",
    "Post approval buttons",
    "Create req in Jira",
    "Post Success to Thread",
    "Resolve Canvas for New REQ",
    "Call 'miles-canvas-area-refresh'",
    "Fetch Thread — Claude Path",
    "Is Duplicate? (Claude Path)",
    "Skip if Duplicate? (Claude Path)",
    "Is Notification Thread — Claude Path?",
    "Is Session Closed — Claude Path?",
    "Post — Context Missing",
    "Post Next Message to Slack",
    "Ignore — Session Closed",
    "Ignore — Miles Not In Thread1"
  ],
