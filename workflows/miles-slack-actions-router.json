    {
      "parameters": {
        "jsCode": "const p = $('Parse & Classify Action').first().json;\nconst issueKey = p.issueKey || '';\nconst triggerId = p.triggerId || '';\nconst results = ($json && $json.results) || [];\nconst options = [];\nfor (const page of results) {\n  try {\n    const pr = page.properties || {};\n    const name = pr['Name'].title[0].plain_text;\n    const jiraId = pr['Jira ID'].rich_text[0].plain_text;\n    if (name && jiraId) options.push({ text:{ type:'plain_text', text:name.slice(0,75) }, value:jiraId });\n  } catch (e) {}\n}\nconst opts = options.slice(0,100);\nconst view = {\n  type:'modal', callback_id:'assign_modal', private_metadata: JSON.stringify({ issueKey }),\n  title:{ type:'plain_text', text:('Asignar '+issueKey).slice(0,24) },\n  submit:{ type:'plain_text', text:'Guardar' }, close:{ type:'plain_text', text:'Cancelar' },\n  blocks:[{ type:'input', block_id:'assignee_block', label:{ type:'plain_text', text:'Responsable' },\n    element:{ type:'static_select', action_id:'assignee_select',\n      placeholder:{ type:'plain_text', text:'Elegí a quién asignar' },\n      options: opts.length ? opts : [{ text:{type:'plain_text',text:'(sin candidatos con Jira ID)'}, value:'none' }] } }]\n};\nreturn [{ json:{ trigger_id:triggerId, view } }];\n"
      },
