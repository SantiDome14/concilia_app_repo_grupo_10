    {
      "parameters": {
        "jsCode": "\n// ============================================================================\n// miles-slack-actions-router · Parse & Classify Action  (hardened)\n// ----------------------------------------------------------------------------\n// Slack manda interacciones como application/x-www-form-urlencoded con un campo\n// `payload` = JSON stringificado. Tolera: (a) body={payload:'<json>'},\n// (b) body='payload=<urlencoded>', (c) body={payload:{obj}}.\n// ============================================================================\n// 🧪 TESTING — Impersonar el usuario que toma. null en produccion.\n const IMPERSONATE = null;\n// const IMPERSONATE = 'D0AEU6S8ES0';\n\nconst body = $json.body !== undefined ? $json.body : $json;\n\nlet payloadRaw;\nif (body && typeof body === 'object' && 'payload' in body) {\n  payloadRaw = body.payload;\n} else if (typeof body === 'string') {\n  const m = body.match(/(?:^|&)payload=([^&]*)/);\n  payloadRaw = m ? decodeURIComponent(m[1].replace(/\\+/g, ' ')) : body;\n} else {\n  payloadRaw = body;\n}\n\nlet payload;\nif (payloadRaw && typeof payloadRaw === 'object') {\n  payload = payloadRaw;\n} else if (typeof payloadRaw === 'string') {\n  try { payload = JSON.parse(payloadRaw); }\n  catch (e1) {\n    try { payload = JSON.parse(decodeURIComponent(payloadRaw.replace(/\\+/g, ' '))); }\n    catch (e2) {\n      return [{ json: { action_type:'unknown', _reason:'parse_error',\n        _bodyType: typeof body, _rawType: typeof payloadRaw,\n        _raw: String(payloadRaw).slice(0, 400) } }];\n    }\n  }\n} else {\n  return [{ json: { action_type:'unknown', _reason:'no_payload',\n    _bodyType: typeof body, _bodyKeys: (body && typeof body==='object') ? Object.keys(body) : null } }];\n}\n\nconst payloadType = payload.type || '';\nconst callbackId  = payload.callback_id || '';\nconst action      = (payload.actions && payload.actions[0]) || {};\nconst actionId    = action.action_id || '';\nconst userId      = (payload.user && payload.user.id) || '';\nconst triggerId   = payload.trigger_id || '';\nconst responseUrl = payload.response_url || '';\n\n// --- Approval (legacy passthrough) ---\nif (callbackId.startsWith('req_approval') || actionId.startsWith('req_approval')) {\n  const rawPayloadString = typeof payloadRaw === 'string' ? payloadRaw : JSON.stringify(payloadRaw);\n  return [{ json: { action_type:'approval', raw_payload:rawPayloadString, callback_id:callbackId } }];\n}\n\n// --- view_submission del modal de asignacion ---\nif (payloadType === 'view_submission' && (payload.view && payload.view.callback_id === 'assign_modal')) {\n  const view = payload.view || {};\n  let issueKey = '';\n  try { issueKey = JSON.parse(view.private_metadata || '{}').issueKey || ''; } catch (e) {}\n  let jiraId = '';\n  try { jiraId = view.state.values.assignee_block.assignee_select.selected_option.value || ''; } catch (e) {}\n  return [{ json: { action_type:'assign_submit', userId, issueKey, jiraId } }];\n}\n\n// --- block_actions ---\nif (payloadType === 'block_actions') {\n  // Pseudo-tab de las vistas tecnicas: home_tab_<fase> -> refresca el Home con esa fase.\n  if (/^home_tab_/.test(actionId)) {\n    const tab = (action.value || actionId.replace(/^home_tab_/, '') || '').toLowerCase();\n    return [{ json: { action_type:'home_tab', userId: IMPERSONATE || userId, tab } }];\n  }\n  if (/^self_assign_/.test(actionId)) {\n    return [{ json: { action_type:'self_assign', userId: IMPERSONATE || userId, issueKey: action.value || actionId.replace(/^self_assign_/,''), responseUrl } }];\n  }\n  if (/^open_assign_/.test(actionId)) {\n    return [{ json: { action_type:'open_assign', userId, issueKey: action.value || actionId.replace(/^open_assign_/,''), triggerId } }];\n  }\n}\n\nreturn [{ json: { action_type:'unknown', _reason:'no_match', payload_type:payloadType, callback_id:callbackId, action_id:actionId } }];\n"
      },
