    {
      "parameters": {
        "jsCode": "const notion = $json || {};\nconst page = (notion.results || [])[0];\nlet jiraId = '';\ntry { jiraId = page.properties['Jira ID'].rich_text[0].plain_text.trim(); } catch (e) { jiraId=''; }\nconst p = $('Parse & Classify Action').first().json;\nconst issueKey = p.issueKey || '';\nconst userId = p.userId || '';\nconst responseUrl = p.responseUrl || '';\nif (!jiraId) return [{ json:{ _ok:false, _reason:'sin Jira ID en Stakeholders', userId, issueKey, responseUrl } }];\nif (!issueKey) return [{ json:{ _ok:false, _reason:'sin issueKey', userId, responseUrl } }];\nreturn [{ json:{ _ok:true, userId, issueKey, jiraId, responseUrl,\n  workitems_body:{ operation:'update', issueKey, fields:{ assignee:{ accountId: jiraId } } } } }];\n"
      },
