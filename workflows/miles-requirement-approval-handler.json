        "jsCode": "// ============================================================================\n// miles-requirement-approval-handler · Resolve Authorization\n// ----------------------------------------------------------------------------\n// Autoriza por CAPABILITIES (modelo nuevo), no por la tabla Area Heads.\n//   1. Business Areas: canal -> area (pageId + Name).\n//   2. Stakeholders:   el aprobador (por Slack ID) con sus Capabilities[] + Business Area[].\n//   3. Capabilities:   resuelve Code -> pageId para 'req.approve.own' y 'req.approve.cross'.\n//\n// Autorizado si:\n//   (tiene req.approve.own  Y  su Business Area == area del canal)   // head del area\n//   O\n//   (tiene req.approve.cross)                                        // universal (Producto + C-Level)\n//\n// Los Code son identificadores semanticos estables del dominio (no UUIDs).\n// Agregar capabilities nuevas NO requiere tocar este flujo: solo importan estas dos.\n// ============================================================================\n\nconst CAP_OWN   = 'req.approve.own';\nconst CAP_CROSS = 'req.approve.cross';\n\nconst p = $('Parse Slack Payload').item.json;\n\n// --- 1. Area del canal ------------------------------------------------------\nconst baResults = $('Query Business Area').item.json.results || [];\nconst areaRow   = baResults[0] || null;\nconst areaPageId = areaRow ? areaRow.id : '';\nconst areaName   = areaRow ? (areaRow.properties?.Name?.title?.[0]?.plain_text || '') : '';\n\n// --- 3. Resolver Code -> pageId de capabilities -----------------------------\nconst capResults = $('Query Capabilities').item.json.results || [];\nlet ownCapId = '', crossCapId = '';\nfor (const c of capResults) {\n  const code = c.properties?.Code?.rich_text?.[0]?.plain_text || '';\n  if (code === CAP_OWN)   ownCapId   = c.id;\n  if (code === CAP_CROSS) crossCapId = c.id;\n}\n\n// --- 2. Stakeholder aprobador ----------------------------------------------\nconst stkResults = $('Query Stakeholder').item.json.results || [];\nconst stk = stkResults[0] || null;\n\nlet isAuthorized = false;\nif (stk) {\n  const caps    = (stk.properties?.Capabilities?.relation || []).map(r => r.id);\n  const stkArea = (stk.properties?.['Business Area']?.relation || []).map(r => r.id);\n\n  const hasOwn   = ownCapId   && caps.includes(ownCapId);\n  const hasCross = crossCapId && caps.includes(crossCapId);\n\n  const isOwnArea = hasOwn && areaPageId && stkArea.includes(areaPageId);\n  isAuthorized = isOwnArea || hasCross;\n}\n\nreturn [{ json: {\n  ...p,\n  area: areaName,        // nombre del area, para el work-items-handler\n  areaPageId,\n  isAuthorized,\n}}];"
      },
