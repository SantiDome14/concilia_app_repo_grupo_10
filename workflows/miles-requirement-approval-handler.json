    {
      "parameters": {
        "jsCode": "// ============================================================================\n// miles-requirement-approval-handler · Parse Slack Payload\n// ----------------------------------------------------------------------------\n// Invocado por miles-slack-actions-router, que reenvia { payload: <string\n// original url-encoded de Slack> }. Solo PARSEA el payload y extrae los datos\n// de la interaccion. La AUTORIZACION se resuelve mas adelante (Resolve\n// Authorization), una vez consultadas Business Areas, Stakeholders y Capabilities.\n// ============================================================================\n\nconst raw = $('Trigger — From Actions Router').item.json.body?.payload\n         || $('Trigger — From Actions Router').item.json.body || '';\nlet payload;\ntry {\n  payload = typeof raw === 'string' ? JSON.parse(decodeURIComponent(raw)) : raw;\n} catch (e) {\n  return [{ json: { error: 'Could not parse payload', raw: String(raw).slice(0,500) } }];\n}\n\n// Idempotencia minima: sin acciones, nada que hacer.\nconst actions = payload.actions || [];\nif (actions.length === 0) {\n  return [{ json: { _abort: true, _reason: 'no_actions' } }];\n}\n\nconst action      = actions[0] || {};\nconst actionValue = action.value || '';\nconst [decision, requesterId] = actionValue.split('__');   // approve|reject __ <requesterSlackId>\n\n// callback_id formato: req_approval_<CHANNELID>_<THREADTS sin punto>\nconst callbackId = payload.callback_id || '';\nconst parts = callbackId.replace('req_approval_', '').split('_');\nconst channelId     = parts[0] || '';\nconst threadTsClean = parts[1] || '';\nconst threadTs      = threadTsClean.slice(0, 10) + '.' + threadTsClean.slice(10);\n\nconst approverId   = payload.user?.id || '';\nconst approverName = payload.user?.name || approverId;\nconst responseUrl  = payload.response_url || '';\n\nreturn [{ json: {\n  decision,        // 'approve' | 'reject'\n  requesterId,     // Slack ID del solicitante\n  approverId,      // Slack ID de quien clickeo\n  approverName,\n  channelId,\n  threadTs,\n  responseUrl,\n  callbackId,\n}}];"
      },
      "id": "761528a1-f11f-4663-a4d1-f048aaa55edd",
      "name": "Parse Slack Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        6848,
        8128
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
