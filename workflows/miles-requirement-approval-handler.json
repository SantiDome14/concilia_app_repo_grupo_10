    },
    {
      "parameters": {
        "jsCode": "\n// Reconstruye los campos del requerimiento parseando los Block Kit del hilo,\n// porque al aprobar el contexto original ya no esta en memoria del workflow.\n// AHORA produce campos NORMALIZADOS para el work-items-handler (no arma el ADF).\nconst msgs = $json.messages || [];\nconst channelId = $('Parse Slack Payload').item.json.channelId;\nconst threadTs  = $('Parse Slack Payload').item.json.threadTs;\n\nconst rootMsg = msgs[0] || {};\nconst elements = rootMsg.blocks?.[0]?.elements?.[0]?.elements || [];\n\nconst extractFromBlocks = (labelText) => {\n  for (let i = 0; i < elements.length; i++) {\n    const el = elements[i];\n    if (el.type === 'text' && el.style?.italic && el.text.trim() === labelText) {\n      let value = '';\n      for (let j = i + 1; j < elements.length; j++) {\n        const next = elements[j];\n        if (next.type === 'text' && next.text === '\\n\\n') break;\n        if (next.type === 'text' && next.text !== '\\n') value += next.text;\n      }\n      return value.trim();\n    }\n  }\n  return '';\n};\n\nconst problema  = extractFromBlocks('Problema');\nconst contexto  = extractFromBlocks('Contexto');\nconst impacto   = extractFromBlocks('Impacto');\nconst resultado = extractFromBlocks('Resultado esperado');\nconst urgencia  = extractFromBlocks('Urgencia') || 'Normal';\n\nconst urgLower = urgencia.toLowerCase();\nlet priority_id = '3';\nif (urgLower.includes('crítico') || urgLower.includes('critico')) priority_id = '1';\nelse if (urgLower.includes('alto'))  priority_id = '2';\nelse if (urgLower.includes('bajo'))  priority_id = '4';\n\nconst area = $('Resolve Authorization').item.json.area || '';\nconst thread_url = 'https://arduasolutions.slack.com/archives/' + channelId + '/p' + threadTs.replace('.', '');\n\nreturn [{ json: {\n  // campos normalizados que consume el work-items-handler\n  problema, contexto, impacto, resultado_esperado: resultado, urgencia,\n  area, priority_id, thread_url,\n  // metadata para nodos siguientes\n  channelId, threadTs,\n} }];\n"
      },
