        "path": "req-approval",
        "options": {}
      },
      "id": "fdcb80cf-2e33-47be-9930-a2abc526ae37",
      "name": "Trigger — From Actions Router",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        6400,
        8128
      ],
      "webhookId": "miles-req-approval"
