      "parameters": {
        "jsCode": "const fullName = $('Fetch Approver Info').item.json.user?.profile?.real_name || $('Parse Slack Payload').item.json.approverName;\nreturn [{ json: { ...$('Parse Slack Payload').item.json, approverDisplayName: fullName } }];"
